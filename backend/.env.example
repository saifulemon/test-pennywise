# Server Configuration
PORT=3000
MODE=DEV
ALLOW_ORIGINS=http://localhost:3000,http://localhost:4000
FRONTEND_URL=http://localhost:5173

# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword
POSTGRES_DATABASE=pennywise

# JWT Configuration
AUTH_JWT_SECRET="your-secret-key-min-32-chars-change-in-production"
AUTH_TOKEN_COOKIE_NAME="PennyWiseToken"
AUTH_TOKEN_EXPIRE_TIME=24h
AUTH_TOKEN_EXPIRED_TIME_REMEMBER_ME=30d
AUTH_REFRESH_TOKEN_COOKIE_NAME="PennyWiseRefreshToken"
AUTH_REFRESH_TOKEN_EXPIRE_TIME=7d

# AWS S3 Configuration (optional)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1

# Email Configuration (Gmail SMTP)
MAIL_PORT=587
MAIL_HOST=smtp.gmail.com
MAIL_FROM=your-email@gmail.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CLIENT_REFRESH_TOKEN=your-google-refresh-token
GOOGLE_CLIENT_ACCESS_TOKEN=your-google-access-token

# Apple Sign In (optional)
APPLE_TEAM_ID=your-apple-team-id
APPLE_CLIENT_ID=your-apple-client-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY=your-apple-private-key

# Firebase Cloud Messaging (for push notifications)
PROJECT_ID=your-firebase-project-id
PRIVATE_KEY_ID=your-firebase-private-key-id
PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-firebase-private-key\n-----END PRIVATE KEY-----"
CLIENT_EMAIL=your-firebase-service-account-email@project-id.iam.gserviceaccount.com
